{%- comment -%} NOMADAX · Especificaciones (cada fila = un bloque editable) {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
<style>
  #nx-sp-{{ uid }} { background: {{ s.color_fondo }}; color: {{ s.color_texto }}; padding: {{ s.padding }}px 0; }
  #nx-sp-{{ uid }} .nx-wrap { max-width:760px; margin:0 auto; padding:0 24px; }
  #nx-sp-{{ uid }} h2 { text-align:center; font-size:clamp(28px,4vw,42px); margin:0 0 24px; font-weight:700; }
  #nx-sp-{{ uid }} table { width:100%; border-collapse:collapse; }
  #nx-sp-{{ uid }} tr { border-bottom:1px solid rgba(255,255,255,.08); }
  #nx-sp-{{ uid }} td { padding:14px 6px; font-size:15px; }
  #nx-sp-{{ uid }} td:first-child { opacity:.7; width:45%; }
  #nx-sp-{{ uid }} td:last-child { font-weight:600; }
</style>
<section id="nx-sp-{{ uid }}">
  <div class="nx-wrap">
    {%- if s.titulo != blank -%}<h2>{{ s.titulo }}</h2>{%- endif -%}
    <table>
      {%- for block in section.blocks -%}
        <tr {{ block.shopify_attributes }}>
          <td>{{ block.settings.etiqueta }}</td>
          <td>{{ block.settings.valor }}</td>
        </tr>
      {%- endfor -%}
    </table>
  </div>
</section>
{% schema %}
{
  "name": "NOMADAX · Especificaciones",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "titulo", "label": "Título", "default": "Especificaciones" },
    { "type": "color", "id": "color_fondo", "label": "Fondo", "default": "#1c1c1e" },
    { "type": "color", "id": "color_texto", "label": "Texto", "default": "#ececec" },
    { "type": "range", "id": "padding", "label": "Espaciado vertical (px)", "min": 24, "max": 140, "step": 4, "default": 88 }
  ],
  "blocks": [
    { "type": "fila", "name": "Fila", "settings": [
      { "type": "text", "id": "etiqueta", "label": "Etiqueta", "default": "Dimensiones" },
      { "type": "text", "id": "valor", "label": "Valor", "default": "40 × 25 × 20 cm" } ] }
  ],
  "presets": [
    { "name": "NOMADAX · Especificaciones", "blocks": [
      { "type": "fila", "settings": { "etiqueta": "Dimensiones", "valor": "40 × 25 × 20 cm" } },
      { "type": "fila", "settings": { "etiqueta": "Volumen", "valor": "~20 L (≈30–35 L con vacío)" } },
      { "type": "fila", "settings": { "etiqueta": "Peso en vacío", "valor": "1,1 – 1,3 kg" } },
      { "type": "fila", "settings": { "etiqueta": "Material exterior", "valor": "Oxford 900D + PU" } },
      { "type": "fila", "settings": { "etiqueta": "Cremalleras", "valor": "YKK AquaGuard estancas" } },
      { "type": "fila", "settings": { "etiqueta": "Portátil", "valor": "Hasta 15,6\"" } },
      { "type": "fila", "settings": { "etiqueta": "Seguridad", "valor": "Candado TSA + bolsillo oculto" } },
      { "type": "fila", "settings": { "etiqueta": "Color", "valor": "Negro mate + tapa beige arena" } }
    ]}
  ]
}
{% endschema %}
